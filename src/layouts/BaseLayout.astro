---
import { ClientRouter } from "astro:transitions";
import Footer from "@/components/Footer.astro";
import Nav from "@/components/Nav.astro";
import { navigationLinks, profile, siteMeta } from "@/data/site";

interface Props {
  title?: string;
  description?: string;
  pageClass?: string;
}

const {
  title = siteMeta.title,
  description = siteMeta.description,
  pageClass = ""
} = Astro.props;
const pageTitle = title === siteMeta.title ? title : `${title} | ${siteMeta.title}`;
const canonical = new URL(Astro.url.pathname, siteMeta.siteUrl).toString();
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`${siteMeta.siteUrl}/social-card.svg`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteMeta.siteUrl}/social-card.svg`} />
    <title>{pageTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600&family=Public+Sans:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
  </head>
  <body class={pageClass}>
    <div class="site-shell">
      <div class="site-noise"></div>
      <div class="site-grid"></div>
      <Nav links={navigationLinks} name={profile.name} />
      <main>
        <slot />
      </main>
      <Footer profile={profile} />
    </div>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
