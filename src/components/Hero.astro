---
import type { SiteProfile } from "@/types";

interface Props {
  profile: SiteProfile;
}

const { profile } = Astro.props;
---

<section class="hero container" id="top">
  <div class="hero__copy reveal" style="--delay: 0.05s;">
    <p class="eyebrow">Research Profile</p>
    <h1>{profile.heroStatement}</h1>
    <p class="hero__lede">{profile.heroDetail}</p>
    <div class="hero__cta">
      <a class="button button--primary" href="/publications/">View Publications</a>
      <a class="button button--ghost" href="/visit-map/">Visitor Map</a>
    </div>
    <div class="hero__metrics">
      {
        profile.metrics.map((metric) => (
          <div class="metric-card">
            <strong>{metric.value}</strong>
            <span>{metric.label}</span>
          </div>
        ))
      }
    </div>
  </div>

  <div class="hero__visual reveal" style="--delay: 0.18s;">
    <div class="portrait-frame">
      <img src={profile.headshot} alt={`Portrait of ${profile.name}`} />
      <div class="portrait-frame__orbit portrait-frame__orbit--one"></div>
      <div class="portrait-frame__orbit portrait-frame__orbit--two"></div>
    </div>
    <div class="hero__annotation">
      <span>Location</span>
      <strong>{profile.location}</strong>
      <p>{profile.title}</p>
    </div>
  </div>
</section>
