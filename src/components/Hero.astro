---
import type { SiteProfile } from "@/types";

interface Props {
  profile: SiteProfile;
}

const { profile } = Astro.props;
---

<section class="hero container" id="top">
  <div class="hero__visual">
    <div class="portrait-frame">
      <img src={profile.headshot} alt={`Portrait of ${profile.name}`} />
    </div>
  </div>

  <div class="hero__copy">
    <h1>{profile.name}</h1>
    <p class="hero__title">{profile.title}</p>
    <p class="hero__location">{profile.location}</p>
    <p class="hero__lede">{profile.heroDetail}</p>
    <p class="hero__statement">{profile.heroStatement}</p>
    <div class="hero__links" aria-label="Profile links">
      <a href="/publications/">Publications</a>
      <a href="/cv/">CV</a>
      <a href="/visit-map/">Visitor map</a>
      {
        profile.socialLinks.map((link) => (
          <a href={link.href} target="_blank" rel="noreferrer">
            {link.label}
          </a>
        ))
      }
    </div>
  </div>
</section>
