---
import SectionHeading from "@/components/SectionHeading.astro";

interface Props {
  items: string[];
}

const { items } = Astro.props;
---

<section class="container section-pad" id="affiliations">
  <SectionHeading
    eyebrow="Affiliations"
    title="Academic and research affiliations"
    intro="Collaborative settings that shape the work across biomedical informatics, clinical data science, and translational research."
  />
  <div class="affiliation-strip">
    {
      items.map((item, index) => (
        <div class="affiliation-pill reveal" style={`--delay: ${0.06 + index * 0.03}s;`}>{item}</div>
      ))
    }
  </div>
</section>
