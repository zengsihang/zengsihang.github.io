---
import Affiliations from "@/components/Affiliations.astro";
import Hero from "@/components/Hero.astro";
import PublicationCard from "@/components/PublicationCard.astro";
import ResearchFocus from "@/components/ResearchFocus.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import Timeline from "@/components/Timeline.astro";
import VisitorMap from "@/components/VisitorMap.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { affiliations, focusAreas, profile, selectedPublications, timeline } from "@/data/site";
---

<BaseLayout>
  <Hero profile={profile} />

  <section class="container section-pad" id="about">
    <div class="detail-grid">
      <article class="detail-card reveal" style="--delay: 0.08s;">
        <p class="eyebrow">About</p>
        <h3>Clinical AI with a longitudinal view</h3>
        <p>{profile.longBio}</p>
      </article>
      <article class="detail-card reveal" style="--delay: 0.15s;">
        <p class="eyebrow">Current Lens</p>
        <h3>AI for healthcare that respects time, uncertainty, and care context</h3>
        <p>
          The throughline is simple: patient records are not isolated events. They are sequences,
          dependencies, missed opportunities, and evolving signals. The research aims to model them that way.
        </p>
      </article>
    </div>
  </section>

  <ResearchFocus focusAreas={focusAreas} />

  <section class="container section-pad" id="publications">
    <SectionHeading
      eyebrow="Selected Work"
      title="Recent papers shaping the narrative"
      intro="A few representative projects spanning trajectory reasoning, biomedical generalists, and evaluation systems."
    />
    <div class="featured-grid">
      {selectedPublications.map((publication) => <PublicationCard publication={publication} featured />)}
    </div>
  </section>

  <Timeline items={timeline} />
  <Affiliations items={affiliations} />

  <section class="container section-pad" id="global-map">
    <VisitorMap compact />
  </section>
</BaseLayout>
